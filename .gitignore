# ============================================================
# LLM Council MGA — Git Ignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
wheels/
*.egg-info/
*.egg

# ── Virtual environments ─────────────────────────────────────
.venv/
myenv/
venv/
env/

# ── Keys, secrets, tokens ───────────────────────────────────
.env
*.pem
*.key

# ── Data files (user-specific) ───────────────────────────────
data/

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Frontend ─────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
.vite/

# ── Testing / Coverage ───────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
*.cover

# ── Docker ───────────────────────────────────────────────────
*.log

# ── OS files ─────────────────────────────────────────────────
desktop.ini
ehthumbs.db

# ── Build artifacts ──────────────────────────────────────────
uv.lock
.python-version

# ── Temp / scratch files ────────────────────────────────────
*.tmp
*.bak
*.png
response_*.json

# ── Deployment results / diagnostics ─────────────────────────
*_result.txt
*_result*.txt
fetchlog*.txt
frontend/frontend-deploy.zip
deploy/quick_test.txt
deploy/test_run.txt
deploy/smoketest_result.txt
deploy/test_data_creation_results.txt
deploy/validate_result.txt