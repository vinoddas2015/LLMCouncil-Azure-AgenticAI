# ============================================================
# LLM Council MGA — Environment Configuration Template
# ============================================================
# Copy to .env and fill in your values
# ============================================================

# ---- API Configuration ----
API_KEY=your-api-key-here
API_BASE_URL=https://chat.int.bayer.com/api/v2/chat/completions

# ---- Server ----
PORT=8001
HOST=0.0.0.0
LOG_LEVEL=info

# ---- Memory Backend ----
# Options: local | redis | cosmosdb
MEMORY_BACKEND=local

# ---- Redis (when MEMORY_BACKEND=redis) ----
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ---- Azure Cosmos DB (conversation history + memory in cloud) ----
# Primary cloud backend — set both to enable. Falls back to Blob / local files.
# COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_KEY=
# COSMOS_DATABASE=llm-council
# COSMOS_CONVERSATIONS_CONTAINER=conversations
# COSMOS_MEMORY_CONTAINER=memory
# COSMOS_SKILLS_CONTAINER=skills

# ---- Azure Blob Storage (file attachments + legacy conversation fallback) ----
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=conversations

# ---- Security ----
# Fernet encryption key for data at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to disable encryption at rest.
ENCRYPTION_KEY=

# PII redaction before external API calls (true/false, default: true)
PII_REDACTION=true

# ---- TLS (optional — for HTTPS in production) ----
# SSL_CERTFILE=/path/to/cert.pem
# SSL_KEYFILE=/path/to/key.pem

# ---- Data Directory (local backend) ----
DATA_DIR=./data
